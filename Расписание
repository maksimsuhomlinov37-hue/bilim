// Весь твой дизайн и данные в одном месте
const style = `
<style>
    :root {
        --bg: #e8f5e9;
        --dark: #c8d6c1;
        --white: #ffffff;
        --green: #2e7d32;
    }
    .bc-container {
        background: var(--bg);
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
        border-radius: 20px;
        color: #333;
    }
    .bc-header { display: flex; align-items: center; margin-bottom: 20px; font-weight: bold; font-size: 14px; }
    .bc-clip { transform: rotate(-45deg); margin-right: 10px; font-size: 20px; }
    
    .bc-days { display: flex; justify-content: space-between; gap: 8px; margin-bottom: 25px; }
    .bc-btn {
        flex: 1; height: 45px; border: none; border-radius: 12px;
        background: var(--bg); color: var(--green); font-weight: bold;
        box-shadow: 5px 5px 10px var(--dark), -5px -5px 10px var(--white);
        cursor: pointer; transition: 0.2s;
    }
    .bc-btn:active, .bc-btn.active {
        box-shadow: inset 4px 4px 8px var(--dark), inset -4px -4px 8px var(--white);
        transform: scale(0.95);
    }

    .bc-lesson {
        background: var(--bg); padding: 15px; margin-bottom: 12px; border-radius: 15px;
        box-shadow: 5px 5px 10px var(--dark), -5px -5px 10px var(--white);
        display: flex; align-items: center; animation: fadeIn 0.3s ease;
    }
    @keyframes fadeIn { from {opacity:0; transform: translateY(10px);} to {opacity:1; transform: translateY(0);} }

    .bc-emoji { font-size: 22px; margin-right: 12px; }
    .bc-time { 
        margin-left: auto; font-size: 11px; padding: 4px 8px; border-radius: 8px;
        box-shadow: inset 2px 2px 5px var(--dark), inset -2px -2px 5px var(--white);
    }
</style>
`;

