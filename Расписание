// Инициализация
document.getElementById('bilimclass-root').innerHTML = style + html;

window.bcRender = function(day, btn) {
    const display = document.getElementById('bc-content');
    display.innerHTML = '';
    
    document.querySelectorAll('.bc-btn').forEach(b => b.classList.remove('active'));
    if(btn) btn.classList.add('active');

    lessons[day].forEach((item, idx) => {
        setTimeout(() => {
            const div = document.createElement('div');
            div.className = 'bc-lesson';
            div.innerHTML = `<span class="bc-emoji">${item.i}</span> <b>${item.n}</b> <span class="bc-time">${item.t}</span>`;
            display.appendChild(div);
        }, idx * 100);
    });
};
